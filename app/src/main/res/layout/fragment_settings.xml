<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingStart="@dimen/spacing_md"
    android:paddingTop="@dimen/spacing_md"
    android:paddingEnd="@dimen/spacing_md"
    android:paddingBottom="@dimen/spacing_lg"
    tools:context=".Fragments.settings">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Language -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_lang_ar"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_lang_selected"
            android:contentDescription="@string/cd_lang_arabic"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="56dp"
            android:text="@string/lang_arabic"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="@dimen/text_body"
            android:textStyle="bold"
            app:backgroundTint="@null"
            app:cornerRadius="@dimen/radius_xl" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_lang_fr"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:background="@drawable/bg_lang_unselected"
            android:contentDescription="@string/cd_lang_french"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="56dp"
            android:text="@string/lang_french"
            android:textAllCaps="false"
            android:textColor="@color/foreground"
            android:textSize="@dimen/text_body"
            android:textStyle="bold"
            app:backgroundTint="@null"
            app:cornerRadius="@dimen/radius_xl"
            app:strokeWidth="0dp" />

        <!-- Display -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:text="@string/settings_display"
            android:textColor="@color/settings_section_label"
            android:textSize="@dimen/text_small"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card"
            app:cardCornerRadius="@dimen/radius_xl"
            app:cardElevation="0dp"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/spacing_md"
                android:paddingTop="@dimen/spacing_xs"
                android:paddingEnd="@dimen/spacing_md"
                android:paddingBottom="@dimen/spacing_xs">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/touch_target"
                    android:paddingTop="@dimen/spacing_sm"
                    android:paddingBottom="@dimen/spacing_sm">

                    <ImageView
                        android:id="@+id/icon_dark_mode"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_moon"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/foreground" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:text="@string/dark_theme"
                        android:textColor="@color/foreground"
                        android:textSize="@dimen/text_body"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/icon_dark_mode"
                        app:layout_constraintStart_toEndOf="@id/dark_mode_switch"
                        app:layout_constraintTop_toTopOf="parent" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/dark_mode_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="@dimen/touch_target"
                        android:minHeight="@dimen/touch_target"
                        android:showText="false"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:thumbTint="@color/white"
                        app:trackTint="@color/settings_switch_track"
                        app:useMaterialThemeColors="false" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/touch_target"
                    android:paddingTop="@dimen/spacing_sm"
                    android:paddingBottom="@dimen/spacing_sm">

                    <ImageView
                        android:id="@+id/icon_large_font"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_text_size"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/foreground" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:text="@string/settings_large_font"
                        android:textColor="@color/foreground"
                        android:textSize="@dimen/text_body"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/icon_large_font"
                        app:layout_constraintStart_toEndOf="@id/large_font_switch"
                        app:layout_constraintTop_toTopOf="parent" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/large_font_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="@dimen/touch_target"
                        android:minHeight="@dimen/touch_target"
                        android:showText="false"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:thumbTint="@color/white"
                        app:trackTint="@color/settings_switch_track"
                        app:useMaterialThemeColors="false" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Accessibility -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:text="@string/settings_accessibility"
            android:textColor="@color/settings_section_label"
            android:textSize="@dimen/text_small"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card"
            app:cardCornerRadius="@dimen/radius_xl"
            app:cardElevation="0dp"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/touch_target"
                android:paddingStart="@dimen/spacing_md"
                android:paddingTop="@dimen/spacing_sm"
                android:paddingEnd="@dimen/spacing_md"
                android:paddingBottom="@dimen/spacing_sm">

                <ImageView
                    android:id="@+id/icon_sounds"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_volume"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/foreground" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    android:text="@string/settings_sounds"
                    android:textColor="@color/foreground"
                    android:textSize="@dimen/text_body"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/icon_sounds"
                    app:layout_constraintStart_toEndOf="@id/sounds_switch"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/sounds_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="@dimen/touch_target"
                    android:minHeight="@dimen/touch_target"
                    android:showText="false"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:thumbTint="@color/white"
                    app:trackTint="@color/settings_switch_track"
                    app:useMaterialThemeColors="false" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- About -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:text="@string/about"
            android:textColor="@color/settings_section_label"
            android:textSize="@dimen/text_small"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card"
            app:cardCornerRadius="@dimen/radius_xl"
            app:cardElevation="0dp"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="@dimen/spacing_lg">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.2"
                    android:text="@string/settings_about_title"
                    android:textColor="@color/foreground"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/app_version_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:gravity="center"
                    android:textColor="@color/muted_foreground"
                    android:textSize="@dimen/text_small"
                    tools:text="الإصدار: 1.3" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:gravity="center"
                    android:text="@string/settings_copyright"
                    android:textColor="@color/muted_foreground"
                    android:textSize="@dimen/text_tiny" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/clear_cache_button"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:minHeight="@dimen/touch_target"
                    android:text="@string/clear_cache"
                    android:textColor="@color/settings_section_label" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_send_feedback"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:background="@drawable/bg_lang_selected"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="56dp"
            android:text="@string/settings_send_feedback"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="@dimen/text_body"
            android:textStyle="bold"
            app:backgroundTint="@null"
            app:cornerRadius="@dimen/radius_xl" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
