<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_sm"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/card"
    app:cardCornerRadius="@dimen/radius_lg"
    app:cardElevation="1dp"
    app:rippleColor="?attr/colorControlHighlight"
    app:strokeColor="@color/border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="@dimen/touch_target"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_md">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@string/favorites"
            android:src="@drawable/ic_bookmark_filled"
            app:tint="@color/primary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/favorite_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="@color/foreground"
                android:textSize="@dimen/text_body"
                android:textStyle="bold"
                tools:text="الوثائق المطلوبة" />

            <TextView
                android:id="@+id/favorite_page"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:textColor="@color/muted_foreground"
                android:textSize="@dimen/text_tiny"
                tools:text="rna" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
